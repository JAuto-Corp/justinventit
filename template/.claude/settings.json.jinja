{%- set mig_variant = 'supabase' if (db_adapter == 'supabase' or database == 'supabase') else ('sql' if (db_adapter == 'postgres' or database == 'postgres') else 'none') -%}
{%- set mig_matcher = 'mcp__supabase__execute_sql|mcp__supabase__apply_migration' if mig_variant == 'supabase' else 'Bash' -%}
{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/guards/write-isolation.sh"
          }
        ]
      }{% if mig_variant != 'none' %},
      {
        "matcher": "{{ mig_matcher }}",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/guards/migration-safety.sh"
          }
        ]
      }{% endif %}
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-start.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-compact.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/stop/runner.sh"
          }
        ]
      }
    ]
  }
}
